{
  "$schema": "vscode://schemas/color-theme",
  "name": "Eidos Proof Light",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#FBFAF7",
    "editor.foreground": "#26323F",
    "editorLineNumber.foreground": "#9AA2AE",
    "editorLineNumber.activeForeground": "#526173",
    "editorCursor.foreground": "#9A6700",
    "editor.selectionBackground": "#D8E5F2",
    "editor.inactiveSelectionBackground": "#E7EDF4",
    "editor.lineHighlightBackground": "#F0F3F6",
    "editorIndentGuide.background1": "#DDE3EA",
    "editorIndentGuide.activeBackground1": "#9AA9B8",
    "editorBracketMatch.background": "#DDEBFA",
    "editorBracketMatch.border": "#0969DA",
    "editorGutter.modifiedBackground": "#0969DA",
    "editorGutter.addedBackground": "#1A7F37",
    "editorGutter.deletedBackground": "#CF222E",
    "editorError.foreground": "#CF222E",
    "editorWarning.foreground": "#9A6700",
    "editorInfo.foreground": "#0969DA",
    "editorHint.foreground": "#6E7781",
    "activityBar.background": "#ECEFF3",
    "sideBar.background": "#F3F5F7",
    "sideBar.foreground": "#26323F",
    "statusBar.background": "#E7ECF2",
    "statusBar.foreground": "#26323F",
    "tab.activeBackground": "#FBFAF7",
    "tab.inactiveBackground": "#ECEFF3",
    "titleBar.activeBackground": "#ECEFF3",
    "titleBar.activeForeground": "#26323F"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#6E7781", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#116329" } },
    { "scope": "constant.numeric, constant.language.boolean", "settings": { "foreground": "#9A6700" } },
    { "scope": "keyword, storage.type", "settings": { "foreground": "#8250DF" } },
    { "scope": "keyword.operator, punctuation.separator, punctuation.definition", "settings": { "foreground": "#57606A" } },
    { "scope": "entity.name.module.eidos", "settings": { "foreground": "#0969DA", "fontStyle": "bold" } },
    { "scope": "entity.name.function.eidos, entity.name.function.call.eidos", "settings": { "foreground": "#1A7F37" } },
    { "scope": "entity.name.function.proof.eidos", "settings": { "foreground": "#8250DF", "fontStyle": "bold" } },
    { "scope": "entity.name.type.eidos, support.type.eidos", "settings": { "foreground": "#9A6700" } },
    { "scope": "entity.name.type.constructor.eidos", "settings": { "foreground": "#B35900" } },
    { "scope": "entity.name.type.trait.eidos", "settings": { "foreground": "#6639BA" } },
    { "scope": "entity.name.type.effect.eidos", "settings": { "foreground": "#BC4C00" } },
    { "scope": "entity.name.variable.eidos, variable.other.eidos", "settings": { "foreground": "#26323F" } },
    { "scope": "variable.parameter.eidos", "settings": { "foreground": "#953800" } },
    { "scope": "variable.other.pattern.eidos", "settings": { "foreground": "#B54708", "fontStyle": "italic" } },
    { "scope": "variable.other.member.field.eidos, variable.other.property.eidos", "settings": { "foreground": "#0A7D86", "fontStyle": "bold" } },
    { "scope": "variable.other.member.access.eidos", "settings": { "foreground": "#0A7D86" } },
    { "scope": "meta.attribute.eidos, entity.name.function.attribute.eidos", "settings": { "foreground": "#BF3989" } }
  ],
  "semanticTokenColors": {
    "module": { "foreground": "#0969DA", "fontStyle": "bold" },
    "function": "#1A7F37",
    "function.declaration": { "foreground": "#1A7F37", "fontStyle": "bold" },
    "method": "#1A7F37",
    "proof": { "foreground": "#8250DF", "fontStyle": "bold" },
    "property": "#0A7D86",
    "fieldLabel": { "foreground": "#0A7D86", "fontStyle": "bold" },
    "variable": "#26323F",
    "variable.mutable": { "foreground": "#CF222E", "fontStyle": "underline" },
    "parameter": "#953800",
    "patternVariable": { "foreground": "#B54708", "fontStyle": "italic" },
    "type": "#9A6700",
    "type.builtin": "#7D4E00",
    "interface": "#6639BA",
    "typeParameter": { "foreground": "#8250DF", "fontStyle": "italic" },
    "effectTag": { "foreground": "#BC4C00", "fontStyle": "bold" },
    "constructor": "#B35900",
    "keyword": "#8250DF",
    "operator": "#57606A",
    "*.effect": { "foreground": "#D1242F", "fontStyle": "italic" },
    "*.unused": { "foreground": "#9AA2AE", "fontStyle": "italic" },
    "*.borrowed": { "foreground": "#0969DA", "fontStyle": "italic" },
    "*.mutableBorrow": { "foreground": "#CF222E", "fontStyle": "italic underline" },
    "*.builtin": { "fontStyle": "bold" }
  }
}
