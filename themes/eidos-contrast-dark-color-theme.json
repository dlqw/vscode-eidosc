{
  "$schema": "vscode://schemas/color-theme",
  "name": "Eidos Contrast Dark",
  "type": "hc",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#080A0E",
    "editor.foreground": "#F2F5F8",
    "editorLineNumber.foreground": "#7F8794",
    "editorLineNumber.activeForeground": "#E6EDF3",
    "editorCursor.foreground": "#FFD866",
    "editor.selectionBackground": "#244A73",
    "editor.inactiveSelectionBackground": "#1A2B3D",
    "editor.lineHighlightBackground": "#111923",
    "editorIndentGuide.background1": "#303844",
    "editorIndentGuide.activeBackground1": "#A6B2C0",
    "editorBracketMatch.background": "#122A3D",
    "editorBracketMatch.border": "#47D1FF",
    "editorGutter.modifiedBackground": "#47D1FF",
    "editorGutter.addedBackground": "#5AF78E",
    "editorGutter.deletedBackground": "#FF5C7A",
    "editorError.foreground": "#FF5C7A",
    "editorWarning.foreground": "#FFD866",
    "editorInfo.foreground": "#47D1FF",
    "editorHint.foreground": "#A6B2C0",
    "activityBar.background": "#05070A",
    "sideBar.background": "#05070A",
    "sideBar.foreground": "#F2F5F8",
    "statusBar.background": "#101722",
    "statusBar.foreground": "#F2F5F8",
    "tab.activeBackground": "#080A0E",
    "tab.inactiveBackground": "#05070A",
    "titleBar.activeBackground": "#05070A",
    "titleBar.activeForeground": "#F2F5F8"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#A6B2C0", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#5AF78E" } },
    { "scope": "constant.numeric, constant.language.boolean", "settings": { "foreground": "#FFD866" } },
    { "scope": "keyword, storage.type", "settings": { "foreground": "#DCA3FF", "fontStyle": "bold" } },
    { "scope": "keyword.operator, punctuation.separator, punctuation.definition", "settings": { "foreground": "#D1D7E0" } },
    { "scope": "entity.name.module.eidos", "settings": { "foreground": "#47D1FF", "fontStyle": "bold" } },
    { "scope": "entity.name.function.eidos, entity.name.function.call.eidos", "settings": { "foreground": "#5AF78E" } },
    { "scope": "entity.name.function.proof.eidos", "settings": { "foreground": "#DCA3FF", "fontStyle": "bold" } },
    { "scope": "entity.name.type.eidos, support.type.eidos", "settings": { "foreground": "#FFD866" } },
    { "scope": "entity.name.type.constructor.eidos", "settings": { "foreground": "#FFCB6B" } },
    { "scope": "entity.name.type.trait.eidos", "settings": { "foreground": "#C7A6FF", "fontStyle": "bold" } },
    { "scope": "entity.name.type.effect.eidos", "settings": { "foreground": "#FF9F43", "fontStyle": "bold" } },
    { "scope": "entity.name.variable.eidos, variable.other.eidos", "settings": { "foreground": "#F2F5F8" } },
    { "scope": "variable.parameter.eidos", "settings": { "foreground": "#FFB86C" } },
    { "scope": "variable.other.pattern.eidos", "settings": { "foreground": "#FFA657", "fontStyle": "italic bold" } },
    { "scope": "variable.other.member.field.eidos, variable.other.property.eidos", "settings": { "foreground": "#7AE7D7", "fontStyle": "bold" } },
    { "scope": "variable.other.member.access.eidos", "settings": { "foreground": "#7AE7D7" } },
    { "scope": "meta.attribute.eidos, entity.name.function.attribute.eidos", "settings": { "foreground": "#FF5C7A" } }
  ],
  "semanticTokenColors": {
    "module": { "foreground": "#47D1FF", "fontStyle": "bold" },
    "function": "#5AF78E",
    "function.declaration": { "foreground": "#5AF78E", "fontStyle": "bold" },
    "method": "#5AF78E",
    "proof": { "foreground": "#DCA3FF", "fontStyle": "bold" },
    "property": "#7AE7D7",
    "fieldLabel": { "foreground": "#7AE7D7", "fontStyle": "bold" },
    "variable": "#F2F5F8",
    "variable.mutable": { "foreground": "#FF5C7A", "fontStyle": "underline" },
    "parameter": "#FFB86C",
    "patternVariable": { "foreground": "#FFA657", "fontStyle": "italic bold" },
    "type": "#FFD866",
    "type.builtin": "#FFE899",
    "interface": { "foreground": "#C7A6FF", "fontStyle": "bold" },
    "typeParameter": { "foreground": "#DCA3FF", "fontStyle": "italic" },
    "effectTag": { "foreground": "#FF9F43", "fontStyle": "bold" },
    "constructor": "#FFCB6B",
    "keyword": { "foreground": "#DCA3FF", "fontStyle": "bold" },
    "operator": "#D1D7E0",
    "*.effect": { "foreground": "#FF8A65", "fontStyle": "italic bold" },
    "*.unused": { "foreground": "#7F8794", "fontStyle": "italic" },
    "*.borrowed": { "foreground": "#47D1FF", "fontStyle": "italic" },
    "*.mutableBorrow": { "foreground": "#FF5C7A", "fontStyle": "italic underline" },
    "*.builtin": { "fontStyle": "bold" }
  }
}
