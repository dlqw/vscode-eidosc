{
  "$schema": "vscode://schemas/color-theme",
  "name": "Eidos Axiom Dark",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#15181D",
    "editor.foreground": "#D8DEE9",
    "editorLineNumber.foreground": "#596170",
    "editorLineNumber.activeForeground": "#A7B0C0",
    "editorCursor.foreground": "#F5D76E",
    "editor.selectionBackground": "#374154",
    "editor.inactiveSelectionBackground": "#2B3341",
    "editor.lineHighlightBackground": "#1D222B",
    "editorIndentGuide.background1": "#2A303A",
    "editorIndentGuide.activeBackground1": "#526071",
    "editorBracketMatch.background": "#2E3A4C",
    "editorBracketMatch.border": "#79C0FF",
    "editorGutter.modifiedBackground": "#7DCFFF",
    "editorGutter.addedBackground": "#8BD49C",
    "editorGutter.deletedBackground": "#F7768E",
    "editorError.foreground": "#FF6B7A",
    "editorWarning.foreground": "#F2C36B",
    "editorInfo.foreground": "#7DCFFF",
    "editorHint.foreground": "#9DADBE",
    "activityBar.background": "#111418",
    "sideBar.background": "#111418",
    "sideBar.foreground": "#C3CAD5",
    "statusBar.background": "#1C222B",
    "statusBar.foreground": "#D8DEE9",
    "tab.activeBackground": "#15181D",
    "tab.inactiveBackground": "#111418",
    "titleBar.activeBackground": "#111418",
    "titleBar.activeForeground": "#D8DEE9"
  },
  "tokenColors": [
    { "scope": "comment", "settings": { "foreground": "#7B8495", "fontStyle": "italic" } },
    { "scope": "string", "settings": { "foreground": "#A6D189" } },
    { "scope": "constant.numeric, constant.language.boolean", "settings": { "foreground": "#E7C173" } },
    { "scope": "keyword, storage.type", "settings": { "foreground": "#C792EA" } },
    { "scope": "keyword.operator, punctuation.separator, punctuation.definition", "settings": { "foreground": "#8D96A8" } },
    { "scope": "entity.name.module.eidos", "settings": { "foreground": "#7DCFFF", "fontStyle": "bold" } },
    { "scope": "entity.name.function.eidos, entity.name.function.call.eidos", "settings": { "foreground": "#8BD49C" } },
    { "scope": "entity.name.function.proof.eidos", "settings": { "foreground": "#E6B3FF", "fontStyle": "bold" } },
    { "scope": "entity.name.type.eidos, entity.name.type.trait.eidos, entity.name.type.effect.eidos, support.type.eidos", "settings": { "foreground": "#F2C36B" } },
    { "scope": "entity.name.type.constructor.eidos", "settings": { "foreground": "#FFB86C" } },
    { "scope": "entity.name.type.trait.eidos", "settings": { "foreground": "#B4A7F5" } },
    { "scope": "entity.name.type.effect.eidos", "settings": { "foreground": "#F29E74" } },
    { "scope": "entity.name.variable.eidos, variable.other.eidos", "settings": { "foreground": "#D8DEE9" } },
    { "scope": "variable.parameter.eidos", "settings": { "foreground": "#E0AF68" } },
    { "scope": "variable.other.pattern.eidos", "settings": { "foreground": "#F5A97F", "fontStyle": "italic" } },
    { "scope": "variable.other.member.field.eidos, variable.other.property.eidos", "settings": { "foreground": "#87C0D0", "fontStyle": "bold" } },
    { "scope": "variable.other.member.access.eidos", "settings": { "foreground": "#87C0D0" } },
    { "scope": "meta.attribute.eidos, entity.name.function.attribute.eidos", "settings": { "foreground": "#F7768E" } }
  ],
  "semanticTokenColors": {
    "module": { "foreground": "#7DCFFF", "fontStyle": "bold" },
    "function": "#8BD49C",
    "function.declaration": { "foreground": "#8BD49C", "fontStyle": "bold" },
    "method": "#8BD49C",
    "proof": { "foreground": "#E6B3FF", "fontStyle": "bold" },
    "property": "#87C0D0",
    "fieldLabel": { "foreground": "#87C0D0", "fontStyle": "bold" },
    "variable": "#D8DEE9",
    "variable.mutable": { "foreground": "#F7768E", "fontStyle": "underline" },
    "parameter": "#E0AF68",
    "patternVariable": { "foreground": "#F5A97F", "fontStyle": "italic" },
    "type": "#F2C36B",
    "type.builtin": "#FFD580",
    "interface": "#B4A7F5",
    "typeParameter": { "foreground": "#DDB6F2", "fontStyle": "italic" },
    "effectTag": { "foreground": "#F29E74", "fontStyle": "bold" },
    "constructor": "#FFB86C",
    "keyword": "#C792EA",
    "operator": "#8D96A8",
    "*.effect": { "foreground": "#FF9E64", "fontStyle": "italic" },
    "*.unused": { "foreground": "#687083", "fontStyle": "italic" },
    "*.borrowed": { "foreground": "#7DCFFF", "fontStyle": "italic" },
    "*.mutableBorrow": { "foreground": "#F7768E", "fontStyle": "italic underline" },
    "*.builtin": { "fontStyle": "bold" }
  }
}
